# DeepSeek API Configuration
# Replace with your actual DeepSeek API credentials
API_KEY=your_deepseek_api_key_here
BASE_URL=https://api.deepseek.com
MODEL=deepseek-chat

# Site URL for sharing posters and sitemap references (Optional)
VITE_SITE_URL=https://your-domain.com

# Target domain to redirect to in production (Optional, e.g., your-domain.com)
VITE_REDIRECT_DOMAIN=your-domain.com

# Google Analytics Measurement ID (Optional, e.g., G-XXXXXXXXXX)
VITE_GA_ID=
